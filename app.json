{
  "expo": {
    "name": "KITmate",
    "slug": "kitmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kitmate",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.abshrimp.kitmate",
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.abshrimp.kitmate"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6EDEF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#286883",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-notifications",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "KitmateTimetable",
              "label": "KITmate 時間割",
              "description": "今日の時間割 (1〜5限)",
              "minWidth": "180dp",
              "minHeight": "180dp",
              "targetCellWidth": 3,
              "targetCellHeight": 3,
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            },
            {
              "name": "KitmateAssignmentDue",
              "label": "KITmate 課題の締切",
              "description": "直近の課題の締切日時",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            },
            {
              "name": "KitmateAssignmentRemaining",
              "label": "KITmate 課題まで",
              "description": "直近の課題までの残り時間",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ],
      "@bacons/apple-targets"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "https://api.kitmate.jp",
      "gaMeasurementId": "",
      "gaApiSecret": "",
      "router": {},
      "eas": {
        "projectId": "e6eba6d1-c77c-451d-901a-b2762799d980"
      }
    },
    "owner": "abshrimp"
  }
}
